{
  "manifest_version": 3,
  "name": "Agentation",
  "version": "0.1.0",
  "description": "Visual feedback for AI coding agents",
  "permissions": ["activeTab", "clipboardWrite", "storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content/main.ts"],
    "run_at": "document_idle"
  }],
  "background": {
    "service_worker": "background/service-worker.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html"
  }
}
