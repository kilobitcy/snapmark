{
  "manifest_version": 3,
  "name": "SnapMark",
  "version": "0.1.4",
  "description": "Annotate web elements and generate AI-ready prompts",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "js": [
        "assets/main.ts-loader-C-gMb-ST.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/messaging-BsnyCUR5.js",
        "assets/main.ts-CA6dXsX_.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
